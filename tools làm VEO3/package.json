{
  "name": "veo3-flow-automation",
  "version": "1.4.8",
  "description": "Công cụ tự động hóa tạo video VEO3 trên Google Flow",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "captcha": "set CAPTCHA_PORT=3456 && node captcha_server.js",
    "electron": "set NODE_ENV=development && electron main.js",
    "build": "node build-secure.js",
    "build:publish": "node build-secure.js --publish"
  },
  "dependencies": {
    "bytenode": "^1.5.7",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "got-scraping": "^4.2.1",
    "multer": "^2.1.1",
    "puppeteer-core": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "selfsigned": "^5.5.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.4.1"
  },
  "build": {
    "appId": "com.inory.veo3",
    "productName": "VEO3 Flow Automation",
    "directories": {
      "output": "C:/Users/1709/Downloads/VEO3-Releases"
    },
    "publish": {
      "provider": "github",
      "owner": "inoryyyyyyyy",
      "repo": "tool-VEO3-app",
      "releaseType": "release",
      "private": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "perMachine": false
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/ffprobe-static/**/*",
      "pickfolder.ps1",
      "hide-taskbar.ps1",
      "brave/**"
    ],
    "extraFiles": [
      {
        "from": "captcha_extension",
        "to": "captcha_extension",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "main.compiled.js"
    },
    "files": [
      "**/*",
      "!ChromeProfile/**",
      "!.chrome-profile/**",
      "!downloads/**",
      "!uploads/**",
      "!*.log",
      "!dom_dump.json",
      "!auth-config.json",
      "!build-secure.js",
      "!_compile_runner.js",
      "!package-lock.json"
    ]
  }
}